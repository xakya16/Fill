import graphics as graph
class column:
    fillColor = "black"
    outlineColor = "white"
    line_width = 1
        
    def __init__(self, p1, p2):
        self.block = graph.Rectangle(p1, p2)
        self.block.setFill(self.fillColor)
        self.block.setOutline(self.outlineColor)
    
    def draw(self, win):
        self.block.draw(win)
    
    def getBlock(self):
        return self.block

class water:
    fillColor = graph.color_rgb(5, 192, 208)

    def __init__(self, p1, p2):
        self.block = graph.Rectangle(p1, p2)
        self.block.setFill(self.fillColor)
        self.block.setOutline(self.fillColor)
    
    def draw(self, win):
        self.block.draw(win)

    def getBlock(self):
        return self.block

def heightCalculation( blockfill ):
    n = len(blockfill)
    maxHeight = blockfill[0][0] + blockfill[0][1]
    for i in range(n):
        totalHeight = blockfill[i][0] + blockfill[i][1]
        if totalHeight > maxHeight:
            maxHeight = totalHeight
    return maxHeight

        
def fill(n, blocks):
    blockGrid = [[blocks[i], 0] for i in range(n)]
    print(blocks)
    fillblocks = 0
    start = 0
    startblock = blocks[start]
    next_greatest = [0, 0]
    while start != n:
        for i in range(start, n - 1):
            if blocks[i] > blocks[i + 1]:
                start = i
                startblock = blocks[start]
                break
        else:
            #print(blockGrid)
            figure(blockGrid)
            return fillblocks
        next_greatest = [blocks[start + 1], start + 1]
        for i in range(start + 1, n):
            if blocks[i] >= startblock:
                for j in range(start + 1, i):
                    #print(j)
                    #print(f"Fillblocks {fillblocks}")
                    blockGrid[j][1] = startblock - blocks[j]
                    fillblocks = fillblocks + ( startblock - blocks[j] )
                for j in range(i, n - 1):
                    if blocks[j] > blocks[j + 1]:
                        #print("Block1")
                        start = j
                        startblock = blocks[start]
                        i = j
                        next_greatest = [blocks[start + 1], start + 1]
                        break
                else:
                    #print(f"Executed1 {i}")
                    #print(blockGrid)
                    figure(blockGrid)
                    return fillblocks
                #startblock = blocks[i]
            if blocks[i] >= next_greatest[0]:
                #print("Block1")
                next_greatest[0] = blocks[i]
                next_greatest[1] = i
        else:
            for i in range(start + 1, next_greatest[1]):
                #print("Executed")
                blockGrid[i][1] = next_greatest[0] - blocks[i]
                fillblocks = fillblocks + ( next_greatest[0] - blocks[i] )
            start = next_greatest[1]
            startblock = blocks[start]
    #print(blockGrid)
    figure(blockGrid)
    return fillblocks

def figure( blockfill ):
    maxHeight = heightCalculation( blockfill )
    width = len(blockfill)
    columnWidth = 40
    height = 40
    margin = 40
    baseHeight = height * maxHeight + margin
    win = graph.GraphWin("Figure", width * columnWidth + 2 * margin, height * maxHeight + margin )
    win.setBackground(graph.color_rgb(225, 225, 225))
    base = graph.Line(graph.Point( margin, baseHeight ), graph.Point( width * columnWidth + margin, baseHeight ))    
    base.draw(win)
    for i in range(width):
        if blockfill[i][0] != 0:
            block = column( graph.Point( i * columnWidth + margin, baseHeight - blockfill[i][0] * height ), graph.Point( ( i + 1 ) * columnWidth + margin, baseHeight ) )
            block.draw(win)
        if blockfill[i][1] != 0:
            fill = water( graph.Point( i * columnWidth + margin, baseHeight - ( height * ( blockfill[i][0] + blockfill[i][1] ) ) ), graph.Point( columnWidth * (i + 1) + margin, baseHeight - height * blockfill[i][0] ) )
            fill.draw(win)
    win.getMouse()
    win.close()
    




